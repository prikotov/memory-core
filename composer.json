{
    "name": "prikotov/memory-core",
    "description": "Key-value storage library with filesystem and other backends",
    "type": "library",
    "license": "MIT",
    "keywords": ["storage", "key-value", "filesystem", "memory", "cache"],
    "authors": [
        {
            "name": "Dmitry Prikotov",
            "email": "prikotov@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Memory\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Memory\\Core\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.4",
        "ext-json": "*",
        "symfony/console": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^2.0",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "bin": [
        "bin/memory"
    ],
    "config": {
        "sort-packages": true,
        "platform-check": true
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse",
        "cs-check": "phpcs --standard=PSR12 src tests",
        "cs-fix": "phpcbf --standard=PSR12 src tests"
    }
}
